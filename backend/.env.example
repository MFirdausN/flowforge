DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flowforge
JWT_SECRET=replace-with-a-local-secret
PORT=3001

# Optional: enables LLM-backed failure analysis.
# Never commit a real API key. Put the real value in backend/.env or CI secrets.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional: when set, webhook calls must include
# x-flowforge-signature: sha256=<hex hmac of JSON body>
WEBHOOK_SECRET=
